<Window x:Class="PcbCam.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCB CAM" Height="690" Width="920" MinHeight="620" MinWidth="760"
        WindowStartupLocation="CenterScreen" Background="#F3F5F8"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
            <RowDefinition Height="76" />
        </Grid.RowDefinitions>

        <Border Background="#172033" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="PCB CAM" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="EasyEDA Gerber → FlatCAM → Carvera" Foreground="#B8C3D8" FontSize="13" Margin="0,5,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StepOneBadge" Background="#087F5B" CornerRadius="14" Padding="10,5"><TextBlock Text="1  Gerber" Foreground="White" /></Border>
                    <TextBlock Text="  ›  " Foreground="#77849C" FontSize="20" />
                    <Border x:Name="StepTwoBadge" Background="#344057" CornerRadius="14" Padding="10,5"><TextBlock Text="2  Project" Foreground="White" /></Border>
                    <TextBlock Text="  ›  " Foreground="#77849C" FontSize="20" />
                    <Border x:Name="StepThreeBadge" Background="#344057" CornerRadius="14" Padding="10,5"><TextBlock Text="3  Build" Foreground="White" /></Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="32,28">
            <Border Background="White" CornerRadius="10" Padding="34" BorderBrush="#E0E4EA" BorderThickness="1">
                <Grid>
                    <Grid x:Name="GerberPage">
                        <StackPanel>
                            <TextBlock Text="Choose your EasyEDA Gerber export" FontSize="24" Foreground="{StaticResource Ink}" FontWeight="SemiBold" />
                            <TextBlock Text="Drop the downloaded .zip anywhere in this window, or browse for it." Foreground="{StaticResource Muted}" FontSize="14" Margin="0,8,0,24" />
                            <Border x:Name="DropZone" Height="210" BorderBrush="#8BBEAE" BorderThickness="2" CornerRadius="8" Background="#F0FAF6">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="↓" FontSize="44" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Drop Gerber .zip here" FontSize="18" Foreground="{StaticResource Ink}" HorizontalAlignment="Center" Margin="0,5,0,14" />
                                    <Button Content="Browse for ZIP" Click="BrowseZip_Click" Background="White" BorderBrush="#B8C1CD" BorderThickness="1" />
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="SelectedZipText" Text="No ZIP selected" Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis" Margin="0,18,0,0" />
                            <TextBlock x:Name="GerberError" Foreground="#B42318" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ProjectPage" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="Where should this project go?" FontSize="24" Foreground="{StaticResource Ink}" FontWeight="SemiBold" />
                            <TextBlock Text="Defaults are filled in from the Gerber filename. The selected folder will contain the new project folder." Foreground="{StaticResource Muted}" FontSize="14" Margin="0,8,0,22" TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="145" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,18,0">
                                <TextBlock Text="Output folder" Foreground="{StaticResource Ink}" Margin="0,0,0,6" />
                                <TextBox x:Name="OutputFolderBox" TextChanged="ProjectField_Changed" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Choose folder…" VerticalAlignment="Bottom" Click="BrowseOutput_Click" Background="#E8ECF2" />
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,20,0,0">
                            <TextBlock Text="Project name" Foreground="{StaticResource Ink}" Margin="0,0,0,6" />
                            <TextBox x:Name="ProjectNameBox" TextChanged="ProjectField_Changed" />
                            <CheckBox x:Name="RefreshExistingBox" IsChecked="True" Margin="0,18,0,0" Foreground="{StaticResource Ink}">
                                <TextBlock Text="Refresh the project if this folder already exists" />
                            </CheckBox>
                            <TextBlock x:Name="ProjectPathPreview" Foreground="{StaticResource Accent}" Margin="0,18,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="ProjectError" Foreground="#B42318" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Row="3" Margin="0,20,0,0">
                            <CheckBox x:Name="UploadToCarveraBox" Checked="UploadToCarvera_Changed" Unchecked="UploadToCarvera_Changed" Foreground="{StaticResource Ink}">
                                <TextBlock Text="Upload generated NC files to my Carvera" />
                            </CheckBox>
                            <Grid x:Name="CarveraOptionsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Carvera IP address" Foreground="{StaticResource Ink}" Margin="0,0,0,6" />
                                    <TextBox x:Name="CarveraHostBox" Text="192.168.1.27" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Carvera work folder" Foreground="{StaticResource Ink}" Margin="0,0,0,6" />
                                    <TextBox x:Name="CarveraFolderBox" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Creates the folder below /sd, then copies every finished cut .nc file. It never starts a machine job." Foreground="{StaticResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="BuildPage" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="BuildTitle" Text="Building your PCB project" FontSize="24" Foreground="{StaticResource Ink}" FontWeight="SemiBold" />
                            <TextBlock x:Name="BuildStage" Text="Checking the toolchain…" Foreground="{StaticResource Muted}" FontSize="15" Margin="0,10,0,24" TextWrapping="Wrap" />
                            <ProgressBar x:Name="BuildProgress" Height="16" Minimum="0" Maximum="100" Value="0" Foreground="{StaticResource Accent}" />
                            <TextBox x:Name="LogBox" Margin="0,24,0,0" Height="260" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="#F7F8FA" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E4EA" BorderThickness="0,1,0,0" Padding="32,14">
            <Grid>
                <Button x:Name="BackButton" Content="Back" HorizontalAlignment="Left" Visibility="Collapsed" Click="Back_Click" Background="#E8ECF2" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel build" Visibility="Collapsed" Click="Cancel_Click" Background="#FEE4E2" Foreground="#B42318" Margin="0,0,12,0" />
                    <Button x:Name="OpenFolderButton" Content="Open project folder" Visibility="Collapsed" Click="OpenFolder_Click" Background="#E8ECF2" Margin="0,0,12,0" />
                    <Button x:Name="NextButton" Content="Next" Style="{StaticResource PrimaryButton}" Click="Next_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
