<Application x:Class="PcbCam.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Ink" Color="#172033" />
        <SolidColorBrush x:Key="Muted" Color="#657084" />
        <SolidColorBrush x:Key="Accent" Color="#087F5B" />
        <SolidColorBrush x:Key="AccentHover" Color="#066B4D" />
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="BorderBrush" Value="#CCD2DC" />
        </Style>
    </Application.Resources>
</Application>
